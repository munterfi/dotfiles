#!/usr/bin/env bash
#===============================================================================
# Name          : mkscr
# Description   : Interactively generates an executable script with a
#                 standardized header, correct shebang, and version info.
# Author        : munterfi <info@munterfinger.ch>
# Date          : 2025-12-15
# Version       : 3.0.0
# Usage         : mkscr
#===============================================================================

set -Eeuo pipefail

# --- Configuration ---
# Colors
BLUE="$(tput setaf 4)"
GREEN="$(tput setaf 2)"
YELLOW="$(tput setaf 3)"
RED="$(tput setaf 1)"
RESET="$(tput sgr0)"

# Layout
DIV_LINE_1="-----------------------------------------------------------------------------"
DIV_LINE_2="============================================================================="

# --- Language Definitions (Easy to extend) ---
# Format: "Display Name"
LANG_OPTIONS=("Bash" "Zsh" "Python" "R" "Julia")

declare -A EXTENSIONS
EXTENSIONS=(
    ["Bash"]="sh"
    ["Zsh"]="sh"
    ["Python"]="py"
    ["R"]="R"
    ["Julia"]="jl"
)

declare -A BINARIES
BINARIES=(
    ["Bash"]="bash"
    ["Zsh"]="zsh"
    ["Python"]="python3"
    ["R"]="Rscript"
    ["Julia"]="julia"
)

# --- Helper Functions ---

log_info()  { echo -e "${BLUE}ℹ${RESET} $*"; }
log_warn()  { echo -e "${YELLOW}⚠${RESET} $*"; }
log_error() { echo -e "${RED}✖${RESET} $*"; exit 1; }

get_tool_version() {
    local cmd="$1"
    if command -v "$cmd" &>/dev/null; then
        # Robustly extract the first occurrence of a version number (e.g., 5.0.17)
        "$cmd" --version 2>&1 | grep -oE '[0-9]+\.[0-9]+\.[0-9]+' | head -n1
    else
        echo "Not Installed"
    fi
}

# --- Main Logic ---

main() {
    clear
    echo -e "${BLUE}mkscr${RESET} :: Script Generator\n"

    # 1. Select Language
    echo "Select a language:"
    PS3="> " # Prompt character
    local lang
    local interpreter
    local ext
    local tool_ver

    select opt in "${LANG_OPTIONS[@]}"; do
        if [[ -n "$opt" ]]; then
            lang="$opt"
            interpreter="${BINARIES[$lang]}"
            ext="${EXTENSIONS[$lang]}"
            break
        else
            log_warn "Invalid selection."
        fi
    done

    # Get version of the selected tool
    tool_ver="$(get_tool_version "$interpreter")"
    log_info "Detected $lang version: $tool_ver"
    echo ""

    # 2. Script Name
    local name_input
    local filename

    while true; do
        read -r -p "Enter script name (without extension): " name_input

        # Sanitize: lowercase and replace spaces with underscores
        name_input="${name_input,,}"
        name_input="${name_input// /_}"

        if [[ -z "$name_input" ]]; then
            log_warn "Name cannot be empty."
            continue
        fi

        filename="${name_input}.${ext}"

        if [[ -e "$filename" ]]; then
            log_warn "File '$filename' already exists. Choose another."
        else
            break
        fi
    done

    # 3. Metadata Inputs (with defaults)
    local description
    local author
    local version
    local current_date

    # Get Git user or fallback to system user
    local git_user
    git_user="$(git config user.name 2>/dev/null) <$(git config user.email 2>/dev/null)>"
    [[ "$git_user" == " <>" ]] && git_user="$(whoami)"

    echo ""
    read -r -p "Description: " description
    read -r -e -i "$git_user" -p "Author: " author
    read -r -e -i "0.1.0" -p "Version: " version

    current_date="$(date +%Y-%m-%d)"

    # 4. Generate File Content
    # Using HEREDOC for cleaner template generation
    cat <<EOF > "$filename"
#!/usr/bin/env $interpreter
# $DIV_LINE_1
# Name          : $filename
# Description   : $description
# Author        : $author
# Date          : $current_date
# Version       : $version
# Usage         : ./$filename
# Notes         :
# $lang          : $tool_ver
# $DIV_LINE_2

# Your code here...

EOF

    # 5. Finalize
    chmod +x "$filename"
    log_info "Created executable: $filename"

    # 6. Open Editor
    # Uses system EDITOR variable, falls back to vim +13 (cursor at code start)
    if [[ -n "${EDITOR:-}" ]]; then
        $EDITOR "$filename"
    else
        vim +13 "$filename"
    fi
}

main