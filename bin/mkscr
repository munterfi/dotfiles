#!/usr/bin/env bash
#===============================================================================
# Name          : mkscr
# Description   : Interactively generates an executable script with a
#                 standardized header, correct shebang, and version info.
# Author        : munterfi <info@munterfinger.ch>
# Date          : 2025-12-15
# Version       : 3.1.0
# Usage         : mkscr
#===============================================================================

# Exit immediately if a command exits with a non-zero status.
set -e

# --- Configuration ---
# Colors
BLUE="$(tput setaf 4)"
GREEN="$(tput setaf 2)"
YELLOW="$(tput setaf 3)"
RESET="$(tput sgr0)"

# Layout
DIV_LINE_1="-----------------------------------------------------------------------------"
DIV_LINE_2="============================================================================="

# --- Language Definitions (Using Bash 4+ Associative Arrays) ---
LANG_OPTIONS=("Bash" "Zsh" "Python" "R")

declare -A EXTENSIONS
EXTENSIONS=(
    ["Bash"]="sh"
    ["Zsh"]="sh"
    ["Python"]="py"
    ["R"]="R"
)

declare -A BINARIES
BINARIES=(
    ["Bash"]="bash"
    ["Zsh"]="zsh"
    ["Python"]="python3"
    ["R"]="Rscript"
)

# --- Helper Functions ---

log_info()  { echo -e "\n${BLUE}ℹ${RESET} $*"; }
log_warn()  { echo -e "${YELLOW}⚠${RESET} $*"; }

get_tool_version() {
    local cmd="$1"
    local version_string=""
    if command -v "$cmd" &>/dev/null; then
        # '|| true' ensures the pipeline succeeds even if grep finds no match
        version_string=$("$cmd" --version 2>&1 | grep -oE '[0-9]+\.[0-9]+(\.[0-9]+)?' | head -n1 || true)
    fi
    echo "${version_string:-Not Found}"
}

# --- Main Logic ---

main() {
    clear
    echo -e "${BLUE}mkscr${RESET} :: Script Generator\n"

    # 1. Select Language
    echo "Select a language:"
    PS3="> " # Prompt character for the select menu
    local lang interpreter ext tool_ver

    select opt in "${LANG_OPTIONS[@]}"; do
        if [[ -n "$opt" ]]; then
            lang="$opt"
            interpreter="${BINARIES[$opt]}"
            ext="${EXTENSIONS[$opt]}"
            break
        else
            log_warn "Invalid selection. Please try again."
        fi
    done

    tool_ver="$(get_tool_version "$interpreter")"
    log_info "Selected $lang ($tool_ver)"
    echo ""

    # 2. Script Name (Robust Input)
    local name_input filename
    while true; do
        printf "Enter script name (without extension): "
        read -r name_input

        # Sanitize using Bash 4+ parameter expansion
        name_input="${name_input,,}" # lowercase
        name_input="${name_input// /_}" # replace spaces with underscores

        if [[ -z "$name_input" ]]; then
            log_warn "Name cannot be empty."
            continue
        fi

        filename="${name_input}.${ext}"

        if [[ -e "$filename" ]]; then
            log_warn "File '$filename' already exists. Choose another."
        else
            break
        fi
    done

    # 3. Metadata Inputs (with defaults)
    local description author version current_date

    local git_user
    git_user="$(git config user.name 2>/dev/null) <$(git config user.email 2>/dev/null)>"
    [[ "$git_user" == " <>" ]] && git_user="$(whoami)"

    echo ""
    printf "Description: "
    read -r description

    printf "Author [%s]: " "$git_user"
    read -r author_input
    author="${author_input:-$git_user}"

    printf "Version [0.1.0]: "
    read -r version_input
    version="${version_input:-0.1.0}"

    current_date="$(date +%Y-%m-%d)"

    # 4. Generate File Content
    cat <<EOF > "$filename"
#!/usr/bin/env $interpreter
# $DIV_LINE_1
# Name          : $filename
# Description   : $description
# Author        : $author
# Date          : $current_date
# Version       : $version
# Usage         : ./$filename
# Notes         :
# $lang          : $tool_ver
# $DIV_LINE_2

# Your code here...

EOF

    # 5. Finalize and Open
    chmod +x "$filename"
    log_info "Created executable: $filename"

    ${EDITOR:-vim} +15 "$filename"
}

main