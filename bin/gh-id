#!/usr/bin/env bash
#===============================================================================
# Name          : git-id
# Description   : Context switcher for Git author identity.
#                 Safe for public dotfiles (prompts for private/work email).
# Author        : munterfi <info@munterfinger.ch>
# Date          : 2025-12-15
# Usage         : git id
#===============================================================================

set -Eeuo pipefail

# --- Configuration (Public Info Only) ---
MY_NAME="Merlin Unterfinger"
MY_PERSONAL_EMAIL="info@munterfinger.ch"

# --- Styling ---
BLUE="$(tput setaf 4)"; GREEN="$(tput setaf 2)"; YELLOW="$(tput setaf 3)"; RESET="$(tput sgr0)"

# --- Pre-flight Checks ---
# Ensure we are inside a git repository
if ! git rev-parse --is-inside-work-tree >/dev/null 2>&1; then
    echo "Error: Not a git repository."
    exit 1
fi

# Get current local config (or global if local isn't set)
curr_name=$(git config user.name || echo "Unset")
curr_email=$(git config user.email || echo "Unset")

# --- UI & Logic ---
echo -e "${BLUE}Git Identity Manager${RESET}"
echo -e "Current: ${YELLOW}$curr_name${RESET} <${YELLOW}$curr_email${RESET}>\n"

PS3="> Select profile: "
options=("Personal ($MY_PERSONAL_EMAIL)" "Work (Manual Input)" "Cancel")

select opt in "${options[@]}"; do
    case "$REPLY" in
        1) # Personal
            new_email="$MY_PERSONAL_EMAIL"
            break
            ;;
        2) # Work
            echo -e "\nEnter work email:"
            read -r new_email
            if [[ -z "$new_email" ]]; then
                echo "Email cannot be empty."
                exit 1
            fi
            break
            ;;
        3) # Cancel
            echo "Cancelled."
            exit 0
            ;;
        *)
            echo "Invalid option."
            ;;
    esac
done

# --- Apply & Verify ---
# We assume Name is the same for both. If not, ask for name in the Work block too.
git config user.name "$MY_NAME"
git config user.email "$new_email"

echo -e "\n${GREEN}✔ Identity updated:${RESET} $MY_NAME <$new_email>"